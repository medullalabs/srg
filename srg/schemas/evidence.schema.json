{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://srg.dev/schemas/evidence.schema.json",
  "title": "EvidenceRecord",
  "description": "Schema for an evidence record emitted during node execution.",
  "type": "object",
  "required": ["graph_name", "node_id", "attempt", "status", "timestamp"],
  "properties": {
    "graph_name": {
      "type": "string",
      "description": "Name of the graph this evidence belongs to."
    },
    "node_id": {
      "type": "string",
      "description": "ID of the node that produced this evidence."
    },
    "attempt": {
      "type": "integer",
      "description": "Attempt number (1-based)."
    },
    "status": {
      "type": "string",
      "enum": ["success", "failure"],
      "description": "Outcome of the node execution attempt."
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of the execution."
    },
    "validation_outcome": {
      "type": ["string", "null"],
      "description": "Result of contract/schema validation."
    },
    "duration_ms": {
      "type": ["number", "null"],
      "description": "Execution duration in milliseconds."
    },
    "prompt_hash": {
      "type": ["string", "null"],
      "description": "Hash of the prompt sent to the LLM (agentic only)."
    },
    "input_hash": {
      "type": ["string", "null"],
      "description": "Hash of the input data."
    },
    "output_hash": {
      "type": ["string", "null"],
      "description": "Hash of the output data."
    },
    "retry_reason": {
      "type": ["string", "null"],
      "description": "Reason for retry if this is a retry attempt."
    },
    "contract_summary": {
      "type": ["string", "null"],
      "description": "Summary of contract evaluation results."
    }
  }
}
